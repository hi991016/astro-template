---
// ===== PROPS =====
interface Props {
  title: string
  description?: string
  ogImage?: string
  lang?: string
  ogLocale?: string
  ogType?: string
  ogSiteName?: string
  typekitId?: string
}

const {
  title,
  description = '',
  ogImage = '',
  lang = 'ja',
  ogLocale = 'ja_JP',
  ogType = 'website',
  ogSiteName = '',
  typekitId = 'KID_ID_HERE'
} = Astro.props

const hasTypekit = typekitId && typekitId !== 'KID_ID_HERE'
const siteNameResolved = ogSiteName || title
const canonical = Astro.url.href.replace(/\/$/, '')
const page = Astro.url.pathname === '/' ? 'home' : Astro.url.pathname.replace(/\//g, '')

// ===== IMPORTS =====
import '@/styles/style.scss'

import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'
import { ClientRouter } from 'astro:transitions';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- @meta -->
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteNameResolved} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />

    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" href="/favicon.ico" />

    <!-- @adobe fonts -->
    {
      hasTypekit && (
        <>
          <link rel="preconnect" href="https://use.typekit.net" crossorigin="" />
          <link rel="preconnect" href="https://p.typekit.net" crossorigin="" />
          <script is:inline define:vars={{ typekitId }}>
            /* eslint-disable */
            (function (d) {
              var config = {
                kitId: typekitId,
                scriptTimeout: 3000,
                active: function () { window.__fontsReady && window.__fontsReady.resolve() },
                inactive: function () {
                  window.__fontsReady && window.__fontsReady.resolve()
                  document.fonts && document.fonts.ready.then(function () {
                    var html = d.documentElement
                    if (html.classList.contains('wf-active')) return
                    html.classList.remove('wf-inactive', 'wf-loading')
                    html.classList.add('wf-active')
                  })
                },
                async: true
              },
                h = d.documentElement, t = setTimeout(function () { h.className = h.className.replace(/\bwf-loading\b/g, "") + " wf-inactive"; }, config.scriptTimeout), tk = d.createElement("script"), f = false, s = d.getElementsByTagName("script")[0], a; h.className += " wf-loading"; tk.src = 'https://use.typekit.net/' + config.kitId + '.js'; tk.async = true; tk.onload = tk.onreadystatechange = function () { a = this.readyState; if (f || a && a != "complete" && a != "loaded") return; f = true; clearTimeout(t); try { Typekit.load(config) } catch (e) { } }; s.parentNode.insertBefore(tk, s)
            })(document);

            window.__fontsReady = (function () {
              var res
              var p = new Promise(function (resolve) { res = resolve })
              p.resolve = res
              return p
            })()
            /* eslint-enable */
          </script>
        </>
      )
    }

    <!-- @astro transition -->
    <ClientRouter fallback="none" />
  </head>

  <body data-page={page}>
    <!-- @header -->
    <Header />
    <!-- @@header -->

    <!-- @main -->
    <slot />
    <!-- @@main -->

    <!-- @footer -->
    <Footer />
    <!-- @@footer -->

    <!-- @page transtion -->
    <div data-transition-screen>
      <div data-transition-inner></div>
    </div>
    <!-- @@page transition -->

    <!-- @custom scrollbar -->
    <div class="c-scrollbar" data-scrollbar>
      <div class="c-scrollbar_thumb" data-scrollbar-thumb></div>
    </div>
    <!-- @@custom scrollbar -->

    <!-- @script -->
    <script>
      import '@/app.js'
    </script>
  </body>
</html>